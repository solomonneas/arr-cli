{
  "name": "@solomonneas/media-cli",
  "version": "2.0.0",
  "description": "Single-file bash CLI for the self-hosted media stack: Sonarr, Radarr, Readarr, Lidarr, Prowlarr, Mylar3, qBittorrent, Bazarr, Jellyseerr, Tdarr, Autobrr, cross-seed, Unpackerr, Recyclarr. Works locally or over SSH.",
  "bin": {
    "media": "media",
    "media-cli": "media"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "bash media help"
  },
  "files": [
    "media",
    "config.example",
    "install.sh",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "sonarr",
    "radarr",
    "prowlarr",
    "qbittorrent",
    "bazarr",
    "jellyseerr",
    "tdarr",
    "arr",
    "media-server",
    "cli",
    "plex",
    "jellyfin",
    "usenet",
    "torrent",
    "media-management"
  ],
  "author": "Solomon Neas <me@solomonneas.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solomonneas/media-cli.git"
  },
  "bugs": {
    "url": "https://github.com/solomonneas/media-cli/issues"
  },
  "homepage": "https://github.com/solomonneas/media-cli#readme",
  "engines": {
    "node": ">=16"
  },
  "os": [
    "linux",
    "darwin"
  ]
}
